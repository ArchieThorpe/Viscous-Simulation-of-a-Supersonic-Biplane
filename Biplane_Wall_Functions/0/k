FoamFile
{
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.001;
    }

    outlet
    {
        type            zeroGradient;
    }

    upperairfoil
    {
        type            kqRWallFunction;
        value           uniform 1e-10;
    }

    lowerairfoil
    {
        type            kqRWallFunction;
        value           uniform 1e-10;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
}


