forceCoeffs1
	{
	
		// Mandatory entries
		type            forceCoeffs;
		libs            ("libforces.so");
		
		writeControl    runTime;
		writeInterval   1; //now every second

		patches         (wing);
		
		// Optional entries
		//Field names
		rhoInf         1.4;
		// Centre of rotation for moment calculations
		CofR            (0 0 0); //Origin of domain and airfoil
                u_mag           1.7;
                alphaDeg        0;
		// Lift direction
		liftDir         ( #calc "-sin(degToRad($alphaDeg))" #calc "cos(degToRad($alphaDeg))" 0 );
		// Drag direction
		dragDir         ( #calc "cos(degToRad($alphaDeg))" #calc "sin(degToRad($alphaDeg))" 0 );
		// Pitch axis
		pitchAxis            (0 0 1); //z-axis
		// Freestream velocity magnitude [m/s]	
		magUInf         1.7;
		
		// Reference length [m]
		lRef            1;
		// Reference area [m2]
		Aref            3.00;
	}


